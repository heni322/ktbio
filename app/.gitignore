# .gitignore for Node.js Web Application

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build outputs
dist/
build/
out/
.next/
.nuxt/
.cache/

# Logs
logs/
*.log

# Operating System Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# Testing
coverage/
.nyc_output/
*.lcov

# Temporary files
tmp/
temp/
*.tmp

# Database files (if using SQLite locally)
*.db
*.sqlite
*.sqlite3

# Package manager lock files (choose one based on your preference)
# Uncomment the one you're NOT using:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Backup files
*.bak
*.backup
*.old

# Compiled files
*.com
*.class
*.dll
*.exe
*.o
*.so

# Compressed files (if generated)
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip

# Production deployment files
.vercel
.netlify

# Debug files
npm-debug.log*
yarn-debug.log*
yarn-error.log*